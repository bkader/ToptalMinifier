# Normalize text files in the repo to LF
* text=auto eol=lf

# Sublime package files
*.sublime-commands text eol=lf
*.sublime-keymap text eol=lf
*.sublime-menu text eol=lf
*.sublime-settings text eol=lf
*.sublime-syntax text eol=lf
*.sublime-color-scheme text eol=lf

# Code / docs
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.cff text eol=lf
*.txt text eol=lf

# Binary / archives
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.zip binary
*.sublime-package binary

# Exclude development/generated files from Package Control release archives
.gitattributes export-ignore
.editorconfig export-ignore
.gitignore export-ignore
CITATION.cff export-ignore
package-metadata.json export-ignore
*.sublime-workspace export-ignore
*.sublime-project export-ignore
__pycache__/ export-ignore
*.py[cod] export-ignore
dist/ export-ignore
build/ export-ignore
